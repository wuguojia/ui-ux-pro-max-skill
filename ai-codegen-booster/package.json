{
  "name": "ai-codegen-booster",
  "version": "1.3.0",
  "description": "AI Code Generation Booster - Import training materials to enhance AI code generation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-data",
    "copy-data": "mkdir -p dist/data && cp -r src/data/*.csv dist/data/",
    "dev": "tsx src/scripts/search.ts",
    "search": "tsx src/scripts/search.ts",
    "extract": "tsx src/cli/commands/extract.ts",
    "validate": "tsx src/cli/commands/validate.ts",
    "import": "tsx src/cli/commands/import.ts",
    "kb": "tsx src/cli/kb.ts",
    "kb:init": "tsx src/cli/kb.ts init",
    "kb:build": "tsx src/cli/kb.ts build",
    "kb:scan": "tsx src/cli/kb.ts scan",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "codegen",
    "code-generation",
    "training",
    "typescript",
    "css-extractor",
    "component-extractor",
    "knowledge-base",
    "skill"
  ],
  "bin": {
    "kb": "./dist/cli/kb.js"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/parser": "^7.23.6",
    "@babel/traverse": "^7.23.6",
    "@babel/types": "^7.23.6",
    "@types/babel__traverse": "^7.20.4",
    "@types/less": "^3.0.6",
    "@types/node": "^22.10.1",
    "@vitest/ui": "^1.1.0",
    "postcss": "^8.4.32",
    "typescript": "^5.7.2",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.4.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "less": "^4.2.0",
    "sass": "^1.69.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
